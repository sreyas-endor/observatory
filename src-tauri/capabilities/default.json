{
  "identifier": "default",
  "description": "Default capabilities for Observatory",
  "windows": ["*"],
  "remote": {
    "urls": ["http://localhost:7337/*"]
  },
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
